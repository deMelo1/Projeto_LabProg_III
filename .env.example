# Configuracao do banco de dados (Postgres)
# Usados pelo container 'db' (variaveis do imagem oficial do postgres)
# e pelo backend (atraves de DATABASE_URL).
POSTGRES_USER=eco
POSTGRES_PASSWORD=eco
POSTGRES_DB=ecofilter

# String de conexao usada pelo backend (FastAPI / SQLAlchemy).
# Use 'db' como host (nome do servico no docker-compose), nao localhost.
DATABASE_URL=postgresql://eco:eco@db:5432/ecofilter

# Portas externas. Devem estar dentro da faixa permitida do grupo.
# Grupo 07 = 8061-8070. Frontend e a porta que abre no navegador.
BACKEND_PORT=8062
FRONTEND_PORT=8061

# URL que o frontend (rodando no navegador do usuario) usa para chamar a API.
# IMPORTANTE: precisa ser o IP do servidor + BACKEND_PORT.
# Para rodar localmente, troque por http://localhost:8062
VITE_API_URL=http://192.168.91.176:8062
